{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "sourceMap": true,
        "strict": true,
        "rootDir": "src",
        "types": ["vitest/globals", "node"]
    },
    "include": [
        "src/__tests__/**/*",
        "src/utils/**/*",
        "src/server/**/*",
        "src/types/**/*"
    ],
    "exclude": [
        "src/__tests__/integration/**/*"
    ]
} 