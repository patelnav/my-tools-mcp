{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "out",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react",
    "baseUrl": ".",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@/*": ["src/*"],
      "@test/*": ["src/__tests__/*"],
      "@utils/*": ["src/utils/*"],
      "@server/*": ["src/server/*"],
      "@types/*": ["src/types/*"],
      "@shared/*": ["src/__tests__/shared/*"],
      "@vitest/*": ["src/__tests__/vitest/*"],
      "@vscode/*": ["src/__tests__/vscode/*"],
      "@fixtures/*": ["src/__tests__/fixtures/*"]
    }
  },
  "include": [
    "src/**/*",
    "*.ts",
    "*.tsx",
    "*.js",
    "*.jsx"
  ],
  "exclude": ["node_modules", ".vscode-test", "dist", "out"]
} 