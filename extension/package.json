{
  "name": "mcp-tools",
  "displayName": "MCP Tools Documentation",
  "version": "1.0.0",
  "description": "MCP-connected tool documentation server with integrated UI",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:mcpTools.openPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mcpTools.openPanel",
        "title": "Open MCP Tools"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts,tsx",
    "test": "jest"
  },
  "dependencies": {
    "@my-tools-mcp/shared": "workspace:*",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/vscode": "^1.60.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "autoprefixer": "^10.4.17",
    "css-loader": "^6.10.0",
    "eslint": "^8.55.0",
    "postcss": "^8.4.33",
    "postcss-loader": "^8.1.0",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.2.2",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4"
  }
} 